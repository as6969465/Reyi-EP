rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // 商品圖片：所有人可讀，管理員可寫
    match /products/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
